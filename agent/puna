#!/usr/bin/env bash
# PUNA entrypoint — model selector wrapper around claudex
# Usage:
#   puna [path]            → deepseek-chat     (fast, default)
#   puna --think [path]    → deepseek-reasoner (R1, thorough)
#   path defaults to $HOST_HOME
set -euo pipefail

if [[ -z "${KUBERNETES_SERVICE_HOST:-}" ]]; then
  echo "[puna] error: must run inside a Kubernetes pod" >&2
  echo "[puna] use: kubectl exec -it -n puna deploy/puna -c claudex -- puna [path]" >&2
  exit 1
fi

if [[ "${1:-}" == "--think" ]]; then
  shift
  export OPENAI_MODEL="deepseek-reasoner"
  echo "[puna] deepseek-reasoner (R1) — expect slower responses"
else
  export OPENAI_MODEL="deepseek-chat"
fi

TARGET="${1:-${HOST_HOME}}"
cd "$TARGET"

exec claudex
